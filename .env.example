# Master compose env template. Copy to `.env` and adjust as needed.
# .env is gitignored; this file is the safe-to-publish template.

# ── Pact Broker ──────────────────────────────────────────────
PACT_DB_PASSWORD=pact
PACT_BROKER_USER=admin
PACT_BROKER_PASSWORD=admin

# ── InfluxDB / Grafana (Phase 3) ─────────────────────────────
INFLUX_ADMIN_USER=k6admin
INFLUX_ADMIN_PASSWORD=changeme
INFLUX_USER=k6writer
INFLUX_USER_PASSWORD=changeme
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Applitools (Phase 1, optional) ───────────────────────────
# APPLITOOLS_API_KEY=

# ── k6 environment registry (Phase 3) ────────────────────────
# K6_ENV=sandbox
# STAGING_BASE_URL=
