# --- node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log

# --- build / dist ---
dist/
build/
*.tsbuildinfo

# --- test artefacts ---
playwright-report/
allure-report/
allure-results/
test-results/
reports/
coverage/
*.junit.xml

# --- env / secrets ---
.env
.env.*
!.env.example
*.pem
*.key

# --- docker / ide / os ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# --- pact ---
pacts/*.json
!pacts/.gitkeep

# --- python (study-guide tooling, if any) ---
__pycache__/
*.pyc
.venv/

# --- nested git histories from the source phase repos ---
# Master is ONE repo at root; nested .git dirs would otherwise become
# accidental submodules. They're stripped before publishing.
phase-*/.git/
phase-*/.auth/
phase-*/.claude/
phase-*/.vscode/

# --- per-phase study guides (kept under docs/study-guides/ at root) ---
phase-*/Phase*-Study-Guide.md
phase-*/phase-*-study-guide.docx
phase-*/phase-*-concepts-study-guide.docx
phase-*/phase-*-cicd-docker-security-study-guide.docx
