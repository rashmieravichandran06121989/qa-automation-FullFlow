# Copy to `.env` for local runs. NEVER commit the real `.env`.

# Which profile tests resolve. One of: sandbox | dev | staging | prod
K6_ENV=sandbox

# Multi-env base URLs (only the active profile is required).
DEV_BASE_URL=https://dev.api.example.com
STAGING_BASE_URL=https://staging.api.example.com
PROD_BASE_URL=

# Bearer tokens per env (leave blank for public endpoints).
DEV_AUTH_TOKEN=
STAGING_AUTH_TOKEN=
PROD_AUTH_TOKEN=

# Observability stack credentials (docker-compose reads these).
INFLUX_ADMIN_USER=k6admin
INFLUX_ADMIN_PASSWORD=change-me
INFLUX_USER=k6writer
INFLUX_USER_PASSWORD=change-me

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
