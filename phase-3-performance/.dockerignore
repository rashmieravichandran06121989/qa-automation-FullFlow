# Keeps the build context tiny and the cache stable across cosmetic edits.

# build / install artefacts
node_modules
dist
coverage

# run artefacts
reports
*.log
*.sarif

# IDE / OS
.git
.github
.idea
.vscode
.DS_Store
Thumbs.db

# docs are not needed inside the runner
docs
README.md
AUDIT-REPORT.md
*.html
*.docx

# scratch / refactor folders
refactored

# secrets — never bake into an image
.env
.env.*
!.env.example
