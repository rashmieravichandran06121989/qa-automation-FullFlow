{
  "title": "k6 — performance overview",
  "uid": "k6-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["k6", "performance", "qa-quality-architect"],
  "timezone": "browser",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
        "query": "SHOW TAG VALUES FROM /http_req_duration|http_reqs/ WITH KEY = endpoint",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "label": "Endpoint"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "p95 latency by endpoint",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "targets": [
        {
          "refId": "A",
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE endpoint =~ /^$endpoint$/ AND $timeFilter GROUP BY time(10s), \"endpoint\" fill(none)",
          "rawQuery": true,
          "alias": "$tag_endpoint"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "min": 0 }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p99 latency by endpoint",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "targets": [
        {
          "refId": "A",
          "query": "SELECT percentile(\"value\", 99) FROM \"http_req_duration\" WHERE endpoint =~ /^$endpoint$/ AND $timeFilter GROUP BY time(10s), \"endpoint\" fill(none)",
          "rawQuery": true,
          "alias": "$tag_endpoint"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "min": 0 } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error rate",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "targets": [
        {
          "refId": "A",
          "query": "SELECT mean(\"value\") FROM \"http_req_failed\" WHERE $timeFilter",
          "rawQuery": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Throughput (req/s)",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "targets": [
        {
          "refId": "A",
          "query": "SELECT non_negative_derivative(count(\"value\"), 1s) FROM \"http_reqs\" WHERE $timeFilter GROUP BY time(5s) fill(0)",
          "rawQuery": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active VUs",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "targets": [
        {
          "refId": "A",
          "query": "SELECT last(\"value\") FROM \"vus\" WHERE $timeFilter",
          "rawQuery": true
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Soak drift — per 5-min bucket",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "description": "Per-bucket p95. A consistent upward staircase across buckets is the canonical soak-test 'creep' signal.",
      "datasource": { "type": "influxdb", "uid": "influxdb-k6" },
      "targets": [
        {
          "refId": "A",
          "query": "SELECT percentile(\"value\", 95) FROM \"soak_response_time_ms\" WHERE $timeFilter GROUP BY time(5m), \"elapsed_bucket\" fill(none)",
          "rawQuery": true,
          "alias": "bucket=$tag_elapsed_bucket"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    }
  ]
}
