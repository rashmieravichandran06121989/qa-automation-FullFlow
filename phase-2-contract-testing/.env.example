# Pact Broker (required for broker-based publish/verify)
PACT_BROKER_BASE_URL=http://localhost:9292
PACT_BROKER_TOKEN=

# Source selector for provider verification
# - unset or 'broker'  → fetch pacts from the broker
# - 'local'            → read from ../pacts/*.json
PACT_SOURCE=local

# CI identity (GitHub Actions injects these automatically)
GITHUB_SHA=
GITHUB_REF_NAME=
CI=

# Provider
PORT=3001
LOG_LEVEL=info

# Consumer — points the client at the pact mock server or a real provider
USER_SERVICE_URL=http://localhost:3001
