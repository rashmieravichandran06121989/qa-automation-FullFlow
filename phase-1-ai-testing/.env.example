# ══════════════════════════════════════════════════════════════════
# qa-ai-automation-framework — environment configuration
# Copy this file to .env and fill in the real values. .env is gitignored.
# ══════════════════════════════════════════════════════════════════

# ── Existing: Applitools (for visual smoke tests) ──
# Get your free key at https://applitools.com
APPLITOOLS_API_KEY=

# ══════════════════════════════════════════════════════════════════
# QA Agent Server (Phase 2) — only needed if you run `npm run agent-server`
# ══════════════════════════════════════════════════════════════════

# ── Server ──
# Port the agent server listens on. Must match qa_server_url in the frontend (default http://localhost:3100).
PORT=3100

# The email address tied to your Atlassian account.
ATLASSIAN_EMAIL=


# ── Playwright screenshots ──
# Folder where captured evidence screenshots are stored. Relative to the framework root.
SCREENSHOT_DIR=playwright-report/evidence

# Default headless mode for screenshot capture (can be overridden per-request).
SCREENSHOT_HEADLESS=true

# ── Automation runner ──
# Max seconds any single Playwright run can take before it's killed.
AUTOMATION_TIMEOUT_SEC=600

# ── AI step implementer (Phase 3) ──
# When "Auto-implement steps" is enabled in the UI, the server launches a
# browser against the target URL, scans the page, and uses an LLM to write
# each Playwright step body. One of these keys must be set for it to work.
#
# Anthropic is strongly preferred — it has no free-tier rate limit, so step
# generation for 8-10 steps finishes in ~5-10 seconds instead of 30-60s.
# Gemini free tier works but caps at 15 RPM so step generation is slower.
#
# Get an Anthropic key at: https://console.anthropic.com (paid, ~$5 minimum)
# Get a Gemini key at:     https://aistudio.google.com/app/apikey (free)
#
# If both are set, Anthropic wins.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
