{
  "name": "qa-ai-automation-framework",
  "version": "1.0.0",
  "description": "AI-augmented Playwright + playwright-bdd + Applitools + Copilot framework against SauceDemo + OrangeHRM. Phase 1 deliverable of my AI-assisted testing upskilling plan.",
  "repository": {
    "type": "git",
    "url": "https://github.com/rashmieravichandran06121989/qa-ai-automation-framework"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npx bddgen && npx playwright test --project='bdd:chromium' --grep-invert @flaky",
    "test:bdd": "npx bddgen && npx playwright test --project='bdd:chromium' --grep-invert @flaky",
    "test:api": "npx playwright test --project=api",
    "test:graphql": "npx playwright test tests/api/graphql.api.test.ts",
    "test:a11y": "npx playwright test --grep @a11y",
    "test:all": "npx bddgen && npx playwright test",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "report:allure:clean": "rm -rf allure-results allure-report",
    "report:portfolio": "cat reports/portfolio/summary.md",
    "lint": "eslint . --ext .ts",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@applitools/eyes-playwright": "^1.37.0",
    "@axe-core/playwright": "^4.10.0",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.46.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-playwright": "^1.6.2",
    "playwright-bdd": "^8.5.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0"
  }
}
